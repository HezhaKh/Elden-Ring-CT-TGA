{$lua}
if syntaxcheck then return end
[ENABLE]
local ON, OFF = true, false
local pending_reload = false

local function EventFlag(flag)
	local state = ef.getFlag(flag):getValue()
	return state
end

local function SetEventFlag(flag, state)
	if state == nil then state = ON end
	ef.setFlag(flag, state)
	print(string.format(" --> Flag %d set to %s", flag, tostring(state)))
end

local function ReloadCharacter()
	print("Requesting a save...")
	writeByte("[GameMan]+B72", 1)
	print("Waiting for save to complete...")
	charaReloadTimer = createTimer(getMainForm())
	charaReloadTimer.Interval = 100
	charaReloadTimer.OnTimer = function(timer)
		local busy = readByte("[GameMan]+B80")
		if busy == 0 then
			print("Save complete. Reloading character.")
			writeInteger("[GameMan]+B78",readInteger("[GameMan]+AC0"))
			print("--- Fast Travel Fix completed ---")
			charaReloadTimer.destroy()
		end
	end
end

local flagRules = {
	{
		name = "Radahn Meteor (Radahn is Alive)",
		enabled = true,
		needs_reload = true,
		condition = function()
			return (EventFlag(310) and not EventFlag(9130))
		end,
		fix = function()
			SetEventFlag(310, OFF)  -- Natural disaster: Green meteorite - 天変地異：緑隕石
