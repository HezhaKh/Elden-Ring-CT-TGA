		fix = function()
			SetEventFlag(72012)    -- Grace: Enir-Ilim: Outer Wall
			SetEventFlag(2110500)   -- Blocks warp sickness
		end
	}
}

local function runFix(rules)
	print("--- Running Fast Travel Fix ---")
	local fixCount = 0
	for _, rule in ipairs(rules) do
		if rule.enabled ~= false then
			if rule.condition() then
				print(string.format("triggered: [%s]", rule.name))
				rule.fix()
				fixCount = fixCount + 1 -- why does Lua not have += or ++, why does CE have to use Lua
				if rule.needs_reload == true then
					pending_reload = true
					print(string.format("Rule [%s] requires character reload. Reloading...", rule.name))
					ReloadCharacter()
				end
			end
		end
	end
	if fixCount == 0 then
		print("No issues found.")
	end
	if pending_reload == false then
			print("--- Fast Travel Fix completed ---")
	end
end

runFix(flagRules)
disableMemrec(memrec)
[DISABLE]
